---
import { NAV_LINKS, TOOLS_LINKS, SITE, TRUST_LINE } from '@/config/site';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';

const year = new Date().getFullYear();

const learnLinks = [
  { label: 'What is Cursor', href: '/learn/what-is-cursor' },
  { label: 'Feature tour', href: '/learn/feature-tour' },
  { label: 'Best practices', href: '/learn/best-practices' },
  { label: 'Security', href: '/learn/security' },
  { label: 'Cost optimization', href: '/learn/cost' },
  { label: 'Enterprise rollout', href: '/learn/enterprise-rollout' },
];
---

<footer class="border-t border-[var(--color-ink-800)] bg-[var(--color-ink-950)]">
  <!-- Footer CTA band -->
  <div class="mx-auto max-w-6xl px-4 py-14">
    <div
      class="relative overflow-hidden rounded-2xl border border-[var(--color-ink-700)] bg-gradient-to-br from-[var(--color-ink-900)] to-[var(--color-ink-850)] p-8 sm:p-10"
    >
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-30"></div>
      <div class="relative flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div class="max-w-xl">
          <h2 class="text-2xl font-bold tracking-tight text-[var(--color-paper-50)]">
            Audit your Cursor setup in 10 seconds
          </h2>
          <p class="mt-2 text-[var(--color-paper-300)]">
            No signup. No upload. Everything runs in your browser. Catch leaked secrets,
            missing <code class="font-mono text-[var(--color-accent-400)]">.cursorignore</code> rules,
            and risky MCP scopes before they cost you.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-3">
          <Button href="/tools/config-analyzer" variant="primary" size="lg" icon="arrow-right">
            Run the audit
          </Button>
          <Button href={SITE.github} variant="secondary" size="lg" icon="github" iconPosition="left" external>
            Star on GitHub
          </Button>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 pb-12">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <a href="/" class="flex items-center gap-2" aria-label={`${SITE.name} home`}>
          <span
            class="flex h-8 w-8 items-center justify-center rounded-md bg-gradient-to-br from-[var(--color-accent-600)] to-[var(--color-cyan-400)] font-mono text-sm font-bold text-white"
            >{'>'}</span
          >
          <span class="font-mono text-sm font-semibold text-[var(--color-paper-50)]">
            Cursor<span class="text-[var(--color-accent-400)]">Craft</span>
          </span>
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-[var(--color-paper-400)]">
          The unofficial community playbook for using Cursor securely, affordably, and at scale.
        </p>
        <p class="mt-4 font-mono text-xs text-[var(--color-paper-400)]">{TRUST_LINE}</p>
      </div>

      <nav aria-label="Guides">
        <p class="mb-3 font-mono text-xs uppercase tracking-wider text-[var(--color-paper-300)]">
          Guides
        </p>
        <ul class="space-y-2">
          {
            learnLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-[var(--color-paper-400)] transition-colors hover:text-[var(--color-paper-100)]"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Tools">
        <p class="mb-3 font-mono text-xs uppercase tracking-wider text-[var(--color-paper-300)]">
          Tools
        </p>
        <ul class="space-y-2">
          {
            TOOLS_LINKS.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-[var(--color-paper-400)] transition-colors hover:text-[var(--color-paper-100)]"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Site">
        <p class="mb-3 font-mono text-xs uppercase tracking-wider text-[var(--color-paper-300)]">
          Site
        </p>
        <ul class="space-y-2">
          {
            NAV_LINKS.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-[var(--color-paper-400)] transition-colors hover:text-[var(--color-paper-100)]"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="/rss.xml"
              class="text-sm text-[var(--color-paper-400)] transition-colors hover:text-[var(--color-paper-100)]"
            >
              RSS feed
            </a>
          </li>
          <li>
            <a
              href={SITE.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-[var(--color-paper-400)] transition-colors hover:text-[var(--color-paper-100)]"
            >
              <Icon name="github" size={14} /> GitHub
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <div
      class="mt-10 flex flex-col gap-3 border-t border-[var(--color-ink-800)] pt-6 text-xs text-[var(--color-paper-400)] sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {SITE.name}. MIT licensed.</p>
      <p class="max-w-md sm:text-right">
        Unofficial community project. Not affiliated with, endorsed by, or sponsored by Anysphere
        or Cursor.
      </p>
    </div>
  </div>
</footer>
