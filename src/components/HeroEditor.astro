---
/**
 * Faux Cursor editor pane — pure CSS, no JS, no layout shift.
 * Used as the hero visual. Decorative; marked aria-hidden.
 */
const codeLines = [
  [{ t: 'kw', v: 'export ' }, { t: 'kw', v: 'function ' }, { t: 'fn', v: 'audit' }, { t: 'p', v: '(' }, { t: 'arg', v: 'config' }, { t: 'p', v: ') {' }],
  [{ t: 'kw', v: '  const ' }, { t: 'var', v: 'findings' }, { t: 'p', v: ' = ' }, { t: 'fn', v: 'rules' }, { t: 'p', v: '.' }, { t: 'fn', v: 'map' }, { t: 'p', v: '((r) => r.' }, { t: 'fn', v: 'check' }, { t: 'p', v: '(config));' }],
  [{ t: 'cm', v: '  // runs entirely in your browser' }],
  [{ t: 'kw', v: '  return ' }, { t: 'var', v: 'findings' }, { t: 'p', v: '.' }, { t: 'fn', v: 'sort' }, { t: 'p', v: '(bySeverity);' }],
  [{ t: 'p', v: '}' }],
];

const colors: Record<string, string> = {
  kw: 'var(--color-syntax-keyword)',
  fn: 'var(--color-syntax-fn)',
  var: 'var(--color-syntax-var)',
  arg: 'var(--color-syntax-string)',
  p: 'var(--color-paper-400)',
  cm: 'var(--color-syntax-comment)',
};
---

<div class="relative" aria-hidden="true">
  <div class="panel shadow-[0_24px_80px_rgba(0,0,0,0.45)]">
    <div class="panel-header">
      <div class="flex min-w-0 flex-1 items-center gap-0.5">
        <span class="editor-tab editor-tab-active shrink-0">analyzer.ts</span>
        <span class="editor-tab shrink-0">rules.ts</span>
        <span class="editor-tab shrink-0">.cursorignore</span>
      </div>
    </div>

    <div class="flex font-mono text-[13px] leading-[1.7]">
      <div class="select-none border-r border-[var(--color-border)] px-3 py-4 text-right text-[var(--color-muted)]">
        {codeLines.map((_, i) => <div>{i + 1}</div>)}
      </div>
      <div class="flex-1 overflow-x-auto py-4 pl-4 pr-6">
        {
          codeLines.map((line, i) => (
            <div class="whitespace-pre">
              {line.map((tok) => (
                <span style={`color:${colors[tok.t]}`}>{tok.v}</span>
              ))}
              {i === 3 && <span class="caret"></span>}
            </div>
          ))
        }
      </div>
    </div>

    <div class="border-t border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 py-3">
      <div class="mb-2 flex items-center gap-2">
        <span class="flex h-5 w-5 items-center justify-center rounded border border-[var(--color-border)] bg-[var(--color-ink-850)] font-mono text-[10px] font-medium text-[var(--color-paper-200)]">C</span>
        <span class="font-mono text-[11px] text-[var(--color-muted)]">Composer · diff</span>
      </div>
      <div class="space-y-1 font-mono text-[12px] leading-snug">
        <div class="rounded bg-[color-mix(in_srgb,var(--color-danger)_12%,transparent)] px-2 py-0.5 text-[var(--color-danger)]">- <span class="text-[var(--color-paper-300)]">apiKey: "sk-live-3f9a...e21"</span></div>
        <div class="rounded bg-[color-mix(in_srgb,var(--color-tip)_12%,transparent)] px-2 py-0.5 text-[var(--color-tip)]">+ <span class="text-[var(--color-paper-300)]">apiKey: process.env.API_KEY</span></div>
      </div>
    </div>

    <div class="status-bar">
      <span>main · TypeScript</span>
      <span>Local-first · no upload</span>
    </div>
  </div>
</div>
