---
interface Props {
  tone?: 'neutral' | 'accent' | 'danger' | 'warn' | 'tip';
  class?: string;
}
const { tone = 'neutral', class: className = '' } = Astro.props;

const tones: Record<string, string> = {
  neutral:
    'bg-[var(--color-ink-850)] text-[var(--color-paper-300)] border-[var(--color-border)]',
  accent:
    'bg-[var(--color-ink-800)] text-[var(--color-paper-200)] border-[var(--color-border-strong)]',
  danger:
    'bg-[color-mix(in_srgb,var(--color-danger)_12%,transparent)] text-[var(--color-danger)] border-[color-mix(in_srgb,var(--color-danger)_35%,transparent)]',
  warn: 'bg-[color-mix(in_srgb,var(--color-warn)_12%,transparent)] text-[var(--color-warn)] border-[color-mix(in_srgb,var(--color-warn)_35%,transparent)]',
  tip: 'bg-[color-mix(in_srgb,var(--color-tip)_12%,transparent)] text-[var(--color-tip)] border-[color-mix(in_srgb,var(--color-tip)_35%,transparent)]',
};
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full border px-2.5 py-0.5 font-mono text-[0.68rem] ${tones[tone]} ${className}`}
>
  <slot />
</span>
