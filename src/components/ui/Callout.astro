---
import Icon from './Icon.astro';
import type { IconName } from './Icon.astro';

interface Props {
  type?: 'info' | 'warn' | 'danger' | 'tip';
  title?: string;
  class?: string;
}

const { type = 'info', title, class: className = '' } = Astro.props;

const config: Record<
  string,
  { icon: IconName; color: string; label: string; border: string; bg: string }
> = {
  info: {
    icon: 'info',
    color: 'var(--color-info)',
    label: 'Note',
    border: 'color-mix(in srgb, var(--color-info) 40%, transparent)',
    bg: 'color-mix(in srgb, var(--color-info) 8%, transparent)',
  },
  warn: {
    icon: 'alert-triangle',
    color: 'var(--color-warn)',
    label: 'Warning',
    border: 'color-mix(in srgb, var(--color-warn) 40%, transparent)',
    bg: 'color-mix(in srgb, var(--color-warn) 8%, transparent)',
  },
  danger: {
    icon: 'alert-octagon',
    color: 'var(--color-danger)',
    label: 'Critical',
    border: 'color-mix(in srgb, var(--color-danger) 40%, transparent)',
    bg: 'color-mix(in srgb, var(--color-danger) 8%, transparent)',
  },
  tip: {
    icon: 'lightbulb',
    color: 'var(--color-tip)',
    label: 'Tip',
    border: 'color-mix(in srgb, var(--color-tip) 40%, transparent)',
    bg: 'color-mix(in srgb, var(--color-tip) 8%, transparent)',
  },
};

const c = config[type] ?? config.info!;
---

<div
  class={`my-5 flex gap-3 rounded-lg border p-4 ${className}`}
  style={`border-color:${c.border}; background:${c.bg}`}
  role="note"
>
  <div class="mt-0.5 shrink-0" style={`color:${c.color}`}>
    <Icon name={c.icon} size={20} />
  </div>
  <div class="min-w-0">
    <p class="mb-1 font-mono text-xs font-medium" style={`color:${c.color}`}>
      {title ?? c.label}
    </p>
    <div class="text-sm leading-relaxed text-[var(--color-paper-200)] [&>p]:mb-2 [&>p:last-child]:mb-0 [&_a]:text-[var(--color-paper-100)] [&_a]:underline">
      <slot />
    </div>
  </div>
</div>
