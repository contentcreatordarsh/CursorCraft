---
import Icon from './Icon.astro';
import type { IconName } from './Icon.astro';

interface Props {
  href?: string;
  icon?: IconName;
  title?: string;
  eyebrow?: string;
  class?: string;
  interactive?: boolean;
}

const {
  href,
  icon,
  title,
  eyebrow,
  class: className = '',
  interactive = Boolean(href),
} = Astro.props;

const Tag = href ? 'a' : 'div';
const base =
  'group relative block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6';
const hover = interactive
  ? 'transition-colors duration-150 hover:border-[var(--color-border-strong)] hover:bg-[var(--color-surface-raised)]'
  : '';
---

<Tag href={href} class={`${base} ${hover} ${className}`}>
  {
    icon && (
      <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-md border border-[var(--color-border)] bg-[var(--color-ink-850)] text-[var(--color-paper-200)]">
        <Icon name={icon} size={20} />
      </div>
    )
  }
  {eyebrow && <p class="mb-1 font-mono text-xs text-[var(--color-muted)]">{eyebrow}</p>}
  {
    title && (
      <h3 class="mb-2 text-lg font-semibold tracking-tight text-[var(--color-paper-50)] group-[a]:group-hover:text-[var(--color-paper-50)]">
        {title}
      </h3>
    )
  }
  <slot />
  {
    href && (
      <span class="mt-4 inline-flex items-center gap-1 font-mono text-xs text-[var(--color-paper-400)] transition-colors group-hover:text-[var(--color-paper-200)]">
        Read more <Icon name="arrow-right" size={14} />
      </span>
    )
  }
</Tag>
