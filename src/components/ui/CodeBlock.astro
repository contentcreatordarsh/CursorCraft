---
import { Code } from 'astro:components';
import Icon from './Icon.astro';

interface Props {
  code: string;
  lang?: string;
  filename?: string;
  showLineNumbers?: boolean;
  class?: string;
}

const {
  code,
  lang = 'plaintext',
  filename,
  showLineNumbers = true,
  class: className = '',
} = Astro.props;

const lineCount = code.replace(/\n$/, '').split('\n').length;
const lineNumbers = Array.from({ length: lineCount }, (_, i) => i + 1);
---

<figure
  class={`overflow-hidden rounded-xl border border-[var(--color-ink-700)] bg-[var(--color-ink-900)] ${className}`}
>
  <figcaption
    class="flex items-center justify-between border-b border-[var(--color-ink-700)] bg-[var(--color-ink-850)] px-3 py-2"
  >
    <div class="flex items-center gap-2">
      <span class="flex gap-1.5" aria-hidden="true">
        <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]/70"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]/70"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]/70"></span>
      </span>
      {
        filename && (
          <span class="ml-2 font-mono text-xs text-[var(--color-paper-300)]">{filename}</span>
        )
      }
    </div>
    <button
      type="button"
      class="copy-btn inline-flex items-center gap-1.5 rounded-md border border-[var(--color-ink-600)] px-2 py-1 font-mono text-[0.7rem] text-[var(--color-paper-300)] transition-colors hover:border-[var(--color-accent-500)] hover:text-white"
      data-code={code}
      aria-label={`Copy ${filename ?? 'code'} to clipboard`}
    >
      <span class="copy-icon"><Icon name="terminal" size={13} /></span>
      <span class="copy-label">Copy</span>
    </button>
  </figcaption>
  <div class="flex overflow-x-auto text-sm">
    {
      showLineNumbers && (
        <div
          aria-hidden="true"
          class="select-none border-r border-[var(--color-ink-700)] bg-[var(--color-ink-900)] px-3 py-4 text-right font-mono text-xs leading-[1.6] text-[var(--color-ink-500)]"
        >
          {lineNumbers.map((n) => (
            <div>{n}</div>
          ))}
        </div>
      )
    }
    <div class="min-w-0 flex-1 py-4 pl-4 pr-6 [&_pre]:!bg-transparent [&_pre]:!m-0 [&_pre]:leading-[1.6]">
      <Code code={code} lang={lang as any} theme="github-dark-default" />
    </div>
  </div>
</figure>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code') ?? '';
      try {
        await navigator.clipboard.writeText(code);
        const label = btn.querySelector('.copy-label');
        if (label) {
          const prev = label.textContent;
          label.textContent = 'Copied!';
          setTimeout(() => {
            label.textContent = prev;
          }, 1600);
        }
      } catch {
        /* clipboard unavailable — fail silently, no user data leaves the page */
      }
    });
  });
</script>
