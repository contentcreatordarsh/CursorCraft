---
/**
 * Zero-JS inline SVG icon set (lucide-style geometry, hand-curated subset).
 * Keeping icons inline avoids shipping an icon runtime to static pages.
 */
interface Props {
  name: IconName;
  size?: number;
  class?: string;
  'aria-hidden'?: boolean;
  title?: string;
}

