---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Callout from '@/components/ui/Callout.astro';
import Icon from '@/components/ui/Icon.astro';
import { articleSchema, faqSchema, breadcrumbSchema } from '@/lib/jsonld';

export const getStaticPaths: GetStaticPaths = async () => {
  const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order);
  return guides.map((guide, i) => ({
    params: { slug: guide.id },
    props: {
      guide,
      prev: i > 0 ? guides[i - 1] : null,
      next: i < guides.length - 1 ? guides[i + 1] : null,
    },
  }));
};

type GuideEntry = CollectionEntry<'guides'>;
interface Props {
  guide: GuideEntry;
  prev: GuideEntry | null;
  next: GuideEntry | null;
}

const { guide, prev, next } = Astro.props as Props;
const { Content, headings } = await render(guide);
const data = guide.data;

const tocHeadings = headings.filter((h) => h.depth === 2);
const ogImage = `/og/guides/${guide.id}.png`;
const url = `/learn/${guide.id}`;

const schemas: Record<string, unknown>[] = [
  articleSchema({
    title: data.title,
    description: data.description,
    url,
    datePublished: data.updated,
    dateModified: data.updated,
    image: ogImage,
    keywords: data.keywords,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Learn', url: '/learn' },
    { name: data.eyebrow, url },
  ]),
];
if (data.faqs.length > 0) schemas.push(faqSchema(data.faqs));
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogImage={ogImage}
  ogType="article"
  jsonLd={schemas}
>
  <div class="mx-auto max-w-6xl px-4 py-10 lg:py-14">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 font-mono text-xs text-[var(--color-paper-400)]">
      <ol class="flex flex-wrap items-center gap-1.5">
        <li><a href="/" class="hover:text-[var(--color-paper-100)]">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/learn" class="hover:text-[var(--color-paper-100)]">Learn</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[var(--color-paper-200)]" aria-current="page">{data.eyebrow}</li>
      </ol>
    </nav>

    <div class="grid gap-12 lg:grid-cols-[1fr_16rem]">
      <article class="min-w-0">
        <header class="mb-8 border-b border-[var(--color-ink-800)] pb-8">
          <div class="mb-4 flex items-center gap-2">
            <Badge tone="accent"><Icon name={data.icon as any} size={12} /> {data.eyebrow}</Badge>
            <span class="font-mono text-xs text-[var(--color-paper-400)]">{data.readingTime}</span>
          </div>
          <h1 class="text-3xl font-bold leading-tight tracking-tight text-[var(--color-paper-50)] sm:text-4xl">
            {data.title}
          </h1>
          <p class="mt-4 text-lg leading-relaxed text-[var(--color-paper-300)]">{data.description}</p>
          <p class="mt-4 font-mono text-xs text-[var(--color-paper-400)]">
            Updated <time datetime={data.updated}>{data.updated}</time>
          </p>
        </header>

        <div class="prose-craft max-w-none">
          <Content components={{ Callout }} />
        </div>

        <!-- Contextual CTA -->
        <div class="mt-12">
          <Callout type="tip" title="Put this into practice">
            <p>
              Check your own setup against this guide in seconds — entirely in your browser.
              <a href={data.ctaHref}>{data.ctaLabel} →</a>
            </p>
          </Callout>
        </div>

        <!-- FAQ -->
        {
          data.faqs.length > 0 && (
            <section class="mt-12" aria-labelledby="faq-heading">
              <h2 id="faq-heading" class="mb-4 text-2xl font-bold text-[var(--color-paper-50)]">
                Frequently asked questions
              </h2>
              <div class="space-y-3">
                {data.faqs.map((f) => (
                  <details class="group rounded-lg border border-[var(--color-ink-700)] bg-[var(--color-ink-900)]/60 p-4">
                    <summary class="flex cursor-pointer items-center justify-between gap-3 font-medium text-[var(--color-paper-100)] marker:content-['']">
                      {f.q}
                      <span class="text-[var(--color-paper-400)] transition-transform group-open:rotate-90">
                        <Icon name="arrow-right" size={16} />
                      </span>
                    </summary>
                    <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-300)]">{f.a}</p>
                  </details>
                ))}
              </div>
            </section>
          )
        }

        <!-- Prev / Next -->
        <nav
          class="mt-12 grid gap-4 border-t border-[var(--color-ink-800)] pt-8 sm:grid-cols-2"
          aria-label="Guide navigation"
        >
          {
            prev ? (
              <a
                href={`/learn/${prev.id}`}
                class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 transition-colors hover:border-[var(--color-border-strong)]"
              >
                <span class="font-mono text-xs text-[var(--color-paper-400)]">← Previous</span>
                <span class="mt-1 block font-medium text-[var(--color-paper-100)] group-hover:text-[var(--color-paper-50)]">
                  {prev.data.title}
                </span>
              </a>
            ) : (
              <span />
            )
          }
          {
            next && (
              <a
                href={`/learn/${next.id}`}
                class="group rounded-lg border border-[var(--color-ink-700)] bg-[var(--color-ink-900)]/60 p-4 text-right transition-colors hover:border-[var(--color-accent-500)] sm:col-start-2"
              >
                <span class="font-mono text-xs text-[var(--color-paper-400)]">Next →</span>
                <span class="mt-1 block font-medium text-[var(--color-paper-100)] group-hover:text-[var(--color-paper-50)]">
                  {next.data.title}
                </span>
              </a>
            )
          }
        </nav>
      </article>

      <!-- TOC sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          {
            tocHeadings.length > 0 && (
              <nav aria-label="On this page">
                <p class="mb-3 font-mono text-xs uppercase tracking-wider text-[var(--color-paper-400)]">
                  On this page
                </p>
                <ul class="space-y-2 border-l border-[var(--color-ink-700)]">
                  {tocHeadings.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class="-ml-px block border-l border-transparent pl-3 text-sm text-[var(--color-paper-400)] transition-colors hover:border-[var(--color-border-strong)] hover:text-[var(--color-paper-100)]"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            )
          }
          <div class="mt-8">
            <Button href={data.ctaHref} variant="primary" size="sm" icon="shield-check" iconPosition="left" class="w-full">
              Audit your setup
            </Button>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
