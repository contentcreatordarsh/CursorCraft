---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConfigAnalyzer from '@/components/analyzer/ConfigAnalyzer.tsx';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
import { softwareApplicationSchema, breadcrumbSchema, faqSchema } from '@/lib/jsonld';

const description =
  'Audit your Cursor configuration in seconds — entirely in your browser. Paste your .cursorignore, .cursor/rules, mcp.json, and settings.json to get a prioritized report of security risks and cost leaks. Nothing is uploaded.';

const faqs = [
  {
    q: 'Is my config uploaded or stored anywhere?',
    a: 'No. The Config Analyzer runs 100% in your browser. There are no network calls with your data, and your file contents are never persisted — they live only in in-memory state and disappear when you close the tab.',
  },
  {
    q: 'What files can I check?',
    a: 'Your .cursorignore, .cursor/rules (or .cursorrules), .cursor/mcp.json, and settings.json. Paste any subset; the analyzer audits what you provide.',
  },
  {
    q: 'What does it look for?',
    a: 'Missing or weak .cursorignore secret coverage, empty or guardrail-free rules, unpinned or over-scoped MCP servers, disabled Privacy Mode, expensive default models, and secrets accidentally pasted into config.',
  },
];

const checks = [
  { icon: 'eye-off', title: 'Secret exposure', body: 'Scans for API keys, tokens, and private keys accidentally pasted into rules, settings, or mcp.json.' },
  { icon: 'shield', title: '.cursorignore coverage', body: 'Flags missing files and gaps for .env, keys, certs, and credential directories.' },
  { icon: 'plug', title: 'MCP least-privilege', body: 'Detects unpinned sources, broad filesystem scopes, and write/admin tokens.' },
  { icon: 'lock', title: 'Privacy Mode', body: 'Warns when settings suggest Privacy Mode is disabled.' },
  { icon: 'wallet', title: 'Cost defaults', body: 'Tips on defaulting to Auto/Composer and avoiding expensive model defaults.' },
  { icon: 'list-checks', title: 'Rules quality', body: 'Checks that rules exist, are non-trivial, and include security guidance.' },
];
---

<BaseLayout
  title="Cursor Config Analyzer — audit your setup in your browser"
  description={description}
  jsonLd={[
    softwareApplicationSchema({
      name: 'Cursor Config Analyzer',
      description,
      url: '/tools/config-analyzer',
    }),
    breadcrumbSchema([
      { name: 'Home', url: '/' },
      { name: 'Tools', url: '/tools' },
      { name: 'Config Analyzer', url: '/tools/config-analyzer' },
    ]),
    faqSchema(faqs),
  ]}
>
  <section class="border-b border-[var(--color-ink-800)]">
    <div class="relative overflow-hidden">
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.12]"></div>
      <div class="relative mx-auto max-w-6xl px-4 py-12 sm:py-16">
        <nav aria-label="Breadcrumb" class="mb-6 font-mono text-xs text-[var(--color-paper-400)]">
          <ol class="flex items-center gap-1.5">
            <li><a href="/" class="hover:text-[var(--color-paper-100)]">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/tools" class="hover:text-[var(--color-paper-100)]">Tools</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-[var(--color-paper-200)]" aria-current="page">Config Analyzer</li>
          </ol>
        </nav>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <Eyebrow>Headline tool</Eyebrow>
            <Badge tone="tip"><Icon name="lock" size={11} /> 100% client-side</Badge>
          </div>
          <h1 class="max-w-3xl text-3xl font-bold tracking-tight text-[var(--color-paper-50)] sm:text-4xl">
            Audit your Cursor setup in seconds
          </h1>
          <p class="max-w-2xl text-lg leading-relaxed text-[var(--color-paper-300)]">
            Paste or upload your config files and get a prioritized report of security risks and cost
            leaks — each with a plain-English explanation and a concrete fix. Everything runs in your
            browser; nothing is ever uploaded.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10" aria-labelledby="analyzer-heading">
    <h2 id="analyzer-heading" class="sr-only">Configuration audit</h2>
    <ConfigAnalyzer client:load />
  </section>

  <!-- What it checks -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <h2 class="mb-6 text-2xl font-bold tracking-tight text-[var(--color-paper-50)]">What it checks</h2>
    <div class="reveal grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        checks.map((c) => (
          <div class="rounded-xl border border-[var(--color-ink-700)] bg-[var(--color-ink-900)]/60 p-5">
            <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--color-ink-600)] bg-[var(--color-ink-800)] text-[var(--color-accent-400)]">
              <Icon name={c.icon as any} size={18} />
            </div>
            <h3 class="font-semibold text-[var(--color-paper-50)]">{c.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-[var(--color-paper-300)]">{c.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 pb-20" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="mb-5 text-2xl font-bold tracking-tight text-[var(--color-paper-50)]">
      Frequently asked questions
    </h2>
    <div class="space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-[var(--color-ink-700)] bg-[var(--color-ink-900)]/60 p-4">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-medium text-[var(--color-paper-100)]">
              {faq.q}
              <span class="text-[var(--color-paper-400)] transition-transform group-open:rotate-90">
                <Icon name="arrow-right" size={16} />
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-300)]">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</BaseLayout>
