---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/ui/Card.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
import { breadcrumbSchema } from '@/lib/jsonld';

const description =
  'Free, local-first tools for Cursor teams. Start with the Config Analyzer — audit your Cursor setup for security risks and cost leaks entirely in your browser.';

const tools = [
  {
    href: '/tools/config-analyzer',
    icon: 'file-search' as const,
    title: 'Config Analyzer',
    body: 'Paste your .cursorignore, rules, mcp.json, and settings to get a prioritized report of security risks and cost leaks. 100% client-side.',
    badge: 'Available now',
    tone: 'tip' as const,
  },
  {
    href: '/tools/rules-generator',
    icon: 'wrench' as const,
    title: 'Rules Generator',
    body: 'Answer a few questions and generate a tailored .cursor/rules file and matching .cursorignore — with security guardrails scaled to your needs. 100% client-side.',
    badge: 'Available now',
    tone: 'tip' as const,
  },
  {
    href: '/tools/rules-templates',
    icon: 'layers' as const,
    title: 'Rules Templates',
    body: 'Curated starters for Next.js, Python, monorepos, and fintech — load into the Rules Generator and customize. 100% client-side.',
    badge: 'Available now',
    tone: 'tip' as const,
  },
  {
    href: '/tools/security-checklist',
    icon: 'list-checks' as const,
    title: 'Security Checklist',
    body: 'A role-based, interactive checklist for ICs, Team Leads, and Security & Ops — track progress with a completion meter. Derived from the security guide.',
    badge: 'Available now',
    tone: 'tip' as const,
  },
  {
    href: '/tools/usage-insights',
    icon: 'gauge' as const,
    title: 'Usage Insights',
    body: 'Step-by-step wizard to export read-only team usage locally, paste the JSON, and see cost hotspots, model mix, and idle seats.',
    badge: 'Available now',
    tone: 'tip' as const,
  },
  {
    href: '/tools/cursorignore-diff',
    icon: 'git-branch' as const,
    title: '.cursorignore Diff',
    body: 'Compare two ignore files or diff your repo against a stack template — spot missing secret and build patterns.',
    badge: 'New',
    tone: 'accent' as const,
  },
  {
    href: '/tools/cost-estimator',
    icon: 'wallet' as const,
    title: 'Cost Estimator',
    body: 'Rough monthly spend range from seats, plan tier, and model mix — no API, for budgeting only.',
    badge: 'New',
    tone: 'accent' as const,
  },
  {
    href: '/tools/rules-linter',
    icon: 'list-checks' as const,
    title: 'Rules & Hooks Linter',
    body: 'Validate .mdc frontmatter, scope, and hooks.json safety before you commit.',
    badge: 'New',
    tone: 'accent' as const,
  },
  {
    href: '/tools/precommit-snippet',
    icon: 'terminal' as const,
    title: 'Pre-commit Snippet',
    body: 'Generate Husky or CI grep checks that block secrets in Cursor config files.',
    badge: 'Available now',
    tone: 'tip' as const,
  },
  {
    href: '/tools/mcp-visualizer',
    icon: 'plug' as const,
    title: 'MCP Visualizer',
    body: 'Paste mcp.json to visualize each server\'s transport, scope, and risk flags — unpinned packages, root mounts, HTTP endpoints.',
    badge: 'Available now',
    tone: 'tip' as const,
  },
  {
    href: '/tools/policy-pack',
    icon: 'layers' as const,
    title: 'Policy Pack',
    body: 'Download a zip with .cursor/rules, .cursorignore, security checklist, and README — commit-ready for your repo.',
    badge: 'New',
    tone: 'accent' as const,
  },
];
---

<BaseLayout
  title="Tools — free, local-first utilities for Cursor teams"
  description={description}
  jsonLd={breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Tools', url: '/tools' },
  ])}
>
  <section class="border-b border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
      <SectionHeading as="h1" eyebrow="Tools" title="Local-first tools, built on principle">
        Every tool here runs in your browser. No backend, no uploads, no telemetry on your code or
        keys — because the best way to teach secure tooling is to build it.
      </SectionHeading>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14" aria-labelledby="tools-heading">
    <h2 id="tools-heading" class="sr-only">Available tools</h2>
    <div class="reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        tools.map((t) => (
          <Card href={t.href} icon={t.icon} title={t.title} class="h-full">
            <Badge tone={t.tone} class="mb-3">
              <Icon name="check" size={11} /> {t.badge}
            </Badge>
            <p class="text-sm leading-relaxed text-[var(--color-paper-300)]">{t.body}</p>
          </Card>
        ))
      }
    </div>
  </section>
</BaseLayout>
