---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RulesGenerator from '@/components/tools/RulesGenerator.tsx';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
import { softwareApplicationSchema, breadcrumbSchema, faqSchema } from '@/lib/jsonld';

const description =
  'Generate a tailored .cursor/rules file and matching .cursorignore for your project in seconds — answer a few questions about your language, framework, testing, and security needs. 100% client-side; nothing is uploaded or stored.';

const faqs = [
  {
    q: 'Is anything I enter uploaded or stored?',
    a: 'No. The generator runs entirely in your browser. There are no network calls, and nothing you type is persisted — not in localStorage, sessionStorage, or any cache. Close the tab and it is gone.',
  },
  {
    q: 'What does it generate?',
    a: 'Two files: a .cursor/rules file (.mdc) encoding your stack, conventions, testing approach, and security guardrails; and a matching .cursorignore tailored to your language, package manager, monorepo layout, and security sensitivity.',
  },
  {
    q: 'Where do I put the generated files?',
    a: 'Save the rules block to .cursor/rules/project.mdc and the ignore block to .cursorignore at your repository root. You can then verify them with the Config Analyzer.',
  },
];

const steps = [
  { icon: 'list-checks', title: 'Answer a few questions', body: 'Language, framework, package manager, testing, monorepo, and security sensitivity.' },
  { icon: 'wrench', title: 'Get tailored config', body: 'A .cursor/rules file and a matching .cursorignore are generated live as you type.' },
  { icon: 'shield-check', title: 'Copy, save, verify', body: 'Copy or download both files, drop them in your repo, then run the Config Analyzer.' },
];
---

<BaseLayout
  title="Cursor Rules Generator — tailored .cursor/rules & .cursorignore"
  description={description}
  jsonLd={[
    softwareApplicationSchema({
      name: 'Cursor Rules Generator',
      description,
      url: '/tools/rules-generator',
    }),
    breadcrumbSchema([
      { name: 'Home', url: '/' },
      { name: 'Tools', url: '/tools' },
      { name: 'Rules Generator', url: '/tools/rules-generator' },
    ]),
    faqSchema(faqs),
  ]}
>
  <section class="border-b border-[var(--color-ink-800)]">
    <div class="relative overflow-hidden">
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.12]"></div>
      <div class="relative mx-auto max-w-6xl px-4 py-12 sm:py-16">
        <nav aria-label="Breadcrumb" class="mb-6 font-mono text-xs text-[var(--color-paper-400)]">
          <ol class="flex items-center gap-1.5">
            <li><a href="/" class="hover:text-[var(--color-paper-100)]">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/tools" class="hover:text-[var(--color-paper-100)]">Tools</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-[var(--color-paper-200)]" aria-current="page">Rules Generator</li>
          </ol>
        </nav>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <Eyebrow>Tool</Eyebrow>
            <Badge tone="tip"><Icon name="lock" size={11} /> 100% client-side</Badge>
          </div>
          <h1 class="max-w-3xl text-3xl font-bold tracking-tight text-[var(--color-paper-50)] sm:text-4xl">
            Generate tailored Cursor rules &amp; .cursorignore
          </h1>
          <p class="max-w-2xl text-lg leading-relaxed text-[var(--color-paper-300)]">
            Answer a few questions about your project and get a ready-to-commit
            <code class="font-mono text-[var(--color-accent-400)]">.cursor/rules</code> file and a
            matching <code class="font-mono text-[var(--color-accent-400)]">.cursorignore</code> —
            with security guardrails scaled to your needs. Everything runs in your browser.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10">
    <RulesGenerator client:load />
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <h2 class="mb-6 text-2xl font-bold tracking-tight text-[var(--color-paper-50)]">How it works</h2>
    <div class="grid gap-4 sm:grid-cols-3">
      {
        steps.map((s, i) => (
          <div class="rounded-xl border border-[var(--color-ink-700)] bg-[var(--color-ink-900)]/60 p-5">
            <div class="mb-3 flex items-center gap-3">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--color-ink-600)] bg-[var(--color-ink-800)] text-[var(--color-accent-400)]">
                <Icon name={s.icon as any} size={18} />
              </span>
              <span class="font-mono text-xs text-[var(--color-paper-400)]">Step {i + 1}</span>
            </div>
            <h3 class="font-semibold text-[var(--color-paper-50)]">{s.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-[var(--color-paper-300)]">{s.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 pb-20" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="mb-5 text-2xl font-bold tracking-tight text-[var(--color-paper-50)]">
      Frequently asked questions
    </h2>
    <div class="space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-[var(--color-ink-700)] bg-[var(--color-ink-900)]/60 p-4">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-medium text-[var(--color-paper-100)]">
              {faq.q}
              <span class="text-[var(--color-paper-400)] transition-transform group-open:rotate-90">
                <Icon name="arrow-right" size={16} />
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-300)]">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</BaseLayout>
