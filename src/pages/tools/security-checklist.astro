---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SecurityChecklist from '@/components/tools/SecurityChecklist.tsx';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
import { softwareApplicationSchema, breadcrumbSchema, faqSchema, howToSchema } from '@/lib/jsonld';
import { ROLES } from '@/lib/security-checklist/data';

const description =
  'An interactive, role-based Cursor security checklist for Individual ICs, Team Leads, and Security & Ops. Track your progress with a completion meter — derived from the CursorCraft security guide. 100% client-side; nothing is saved or uploaded.';

const faqs = [
  {
    q: 'Is my checklist progress saved?',
    a: 'No. Progress is tracked in memory only for the life of the page. Nothing is written to localStorage, sessionStorage, or any server. Refreshing the page clears it.',
  },
  {
    q: 'Which role should I pick?',
    a: 'Pick the one that matches your responsibility. Individual ICs focus on day-to-day habits, Team Leads on making the secure setup the default for a team, and Security & Ops on enforcing org-wide policy and governance. You can work through all three.',
  },
  {
    q: 'Where does the checklist come from?',
    a: 'Every item is derived from the CursorCraft security guide, with a short "why" and a link to the relevant section so you can go deeper.',
  },
];

// HowTo steps from the Individual IC role (the most universal set).
const icRole = ROLES.find((r) => r.id === 'ic') ?? ROLES[0]!;
const howToSteps = icRole.items.map((i) => ({ name: i.label, text: i.why }));
---

<BaseLayout
  title="Cursor Security Checklist — role-based, interactive"
  description={description}
  jsonLd={[
    softwareApplicationSchema({
      name: 'Cursor Security Checklist',
      description,
      url: '/tools/security-checklist',
    }),
    howToSchema({
      name: 'Secure your Cursor setup (Individual IC)',
      description:
        'A step-by-step checklist to secure your individual Cursor setup, from Privacy Mode to handling untrusted input.',
      url: '/tools/security-checklist',
      steps: howToSteps,
    }),
    breadcrumbSchema([
      { name: 'Home', url: '/' },
      { name: 'Tools', url: '/tools' },
      { name: 'Security Checklist', url: '/tools/security-checklist' },
    ]),
    faqSchema(faqs),
  ]}
>
  <section class="border-b border-[var(--color-ink-800)]">
    <div class="relative overflow-hidden">
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-[0.12]"></div>
      <div class="relative mx-auto max-w-6xl px-4 py-12 sm:py-16">
        <nav aria-label="Breadcrumb" class="mb-6 font-mono text-xs text-[var(--color-paper-400)]">
          <ol class="flex items-center gap-1.5">
            <li><a href="/" class="hover:text-[var(--color-paper-100)]">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/tools" class="hover:text-[var(--color-paper-100)]">Tools</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-[var(--color-paper-200)]" aria-current="page">Security Checklist</li>
          </ol>
        </nav>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <Eyebrow>Tool</Eyebrow>
            <Badge tone="tip"><Icon name="lock" size={11} /> In-memory only</Badge>
          </div>
          <h1 class="max-w-3xl text-3xl font-bold tracking-tight text-[var(--color-paper-50)] sm:text-4xl">
            Role-based Cursor security checklist
          </h1>
          <p class="max-w-2xl text-lg leading-relaxed text-[var(--color-paper-300)]">
            Pick your role and work through a tailored checklist derived from the
            <a href="/learn/security" class="text-[var(--color-accent-400)] underline">security guide</a>.
            Track progress with a completion meter; expand any item to see why it matters. Nothing is
            saved or uploaded.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-10">
    <SecurityChecklist client:load />
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-20" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="mb-5 text-2xl font-bold tracking-tight text-[var(--color-paper-50)]">
      Frequently asked questions
    </h2>
    <div class="space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-[var(--color-ink-700)] bg-[var(--color-ink-900)]/60 p-4">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-medium text-[var(--color-paper-100)]">
              {faq.q}
              <span class="text-[var(--color-paper-400)] transition-transform group-open:rotate-90">
                <Icon name="arrow-right" size={16} />
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-300)]">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</BaseLayout>
